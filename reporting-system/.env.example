# Urban Infrastructure Monitor - Environment Configuration

# Backend API Configuration
REACT_APP_API_BASE_URL=http://localhost:5216

# Authentication Endpoints
REACT_APP_AUTH_LOGIN_URL=/api/Auth/login
REACT_APP_AUTH_REGISTER_URL=/api/Auth/register
REACT_APP_AUTH_REFRESH_URL=/api/Auth/refresh

# Application Settings
REACT_APP_TOKEN_STORAGE_KEY=accessToken
REACT_APP_REFRESH_TOKEN_KEY=refreshToken

# Google Maps Configuration
# Get your API key from: https://console.cloud.google.com/
# Required APIs to enable:
# - Maps JavaScript API
# Steps:
# 1. Go to Google Cloud Console
# 2. Create a new project
# 3. Enable "Maps JavaScript API"
# 4. Go to Credentials and create an API key
# 5. Restrict to JavaScript applications and HTTP referrers
# 6. Add the key here
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

